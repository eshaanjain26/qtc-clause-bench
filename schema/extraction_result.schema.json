{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "QuoteToCashExtractionResult",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract_id", "pricing_tier", "discount_threshold", "renewal_term", "msa_sow_linkage"],
  "properties": {
    "contract_id": { "type": "string" },
    "annotation_note": {
      "type": "string",
      "description": "Ground-truth-only field. Explains a non-obvious labeling call. Never produced by the extraction pipeline and never scored."
    },
    "pricing_tier": {
      "type": "object",
      "additionalProperties": false,
      "required": ["present", "tiers", "quote_span"],
      "properties": {
        "present": { "type": "boolean" },
        "tiers": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["threshold_low", "unit_price", "unit"],
            "properties": {
              "threshold_low": { "type": "number" },
              "threshold_high": { "type": ["number", "null"] },
              "unit_price": { "type": "number" },
              "unit": { "type": "string" },
              "currency": { "type": "string", "default": "USD" }
            }
          }
        },
        "quote_span": { "type": "string" },
        "annotation_note": { "type": "string" }
      }
    },
    "discount_threshold": {
      "type": "object",
      "additionalProperties": false,
      "required": ["present", "discount_percent", "trigger_type", "quote_span"],
      "properties": {
        "present": { "type": "boolean" },
        "discount_percent": { "type": ["number", "null"] },
        "trigger_type": {
          "type": "string",
          "enum": ["annual_contract_value", "volume", "multi_year_commitment", "one_time_purchase", "none"]
        },
        "trigger_value": { "type": ["number", "null"] },
        "trigger_unit": { "type": ["string", "null"] },
        "quote_span": { "type": "string" },
        "annotation_note": { "type": "string" }
      }
    },
    "renewal_term": {
      "type": "object",
      "additionalProperties": false,
      "required": ["present", "renewal_type", "quote_span"],
      "properties": {
        "present": { "type": "boolean" },
        "renewal_type": { "type": "string", "enum": ["auto", "manual", "none"] },
        "initial_term_months": { "type": ["number", "null"] },
        "renewal_term_months": { "type": ["number", "null"] },
        "notice_period_days": { "type": ["number", "null"] },
        "price_escalation_percent": { "type": ["number", "null"] },
        "quote_span": { "type": "string" },
        "annotation_note": { "type": "string" }
      }
    },
    "msa_sow_linkage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["present", "reference_type", "quote_span"],
      "properties": {
        "present": { "type": "boolean" },
        "reference_type": {
          "type": "string",
          "enum": ["date", "title_and_date", "exhibit_number", "unspecified", "none"]
        },
        "referenced_document": { "type": ["string", "null"] },
        "order_of_precedence_note": { "type": ["string", "null"] },
        "quote_span": { "type": "string" },
        "annotation_note": { "type": "string" }
      }
    }
  }
}
